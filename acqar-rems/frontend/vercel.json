{
  "github": {
    "autoAlias": true
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://acqar-signal-production.up.railway.app/api/$1"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "https://acqar-signal-production.up.railway.app/socket.io/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]

  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "www.signal.acqar.com" }],
      "destination": "https://acqar.com",
      "permanent": false
    }
  ]
}
